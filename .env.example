# ============================================================
# CompetiTour Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=competitour
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_DB=competitour
DATABASE_URL=postgresql+asyncpg://competitour:changeme_pg_password@postgres:5432/competitour

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Torch Labs Proxy ----------
TORCH_GATEWAY_HOST=geox.torchproxies.com
TORCH_GATEWAY_PORT=6011
TORCH_USERNAME=your_torch_username
TORCH_PASSWORD=your_torch_password

# ---------- Anthropic (Claude) ----------
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ---------- JWT Auth ----------
JWT_SECRET_KEY=changeme_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ---------- App ----------
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
